# Supabase Connection configuration
# Direct connection string for administrative tasks/migrations (runs on backend startup)
DATABASE_URL=postgresql://postgres:your-db-password@db.xxxxxx.supabase.co:5432/postgres

# Client connection parameters (for Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Gemini API key (for Resume Parser, ATS Scorer, and Job Matcher)
GEMINI_API_KEY=your_gemini_api_key

# App settings
NODE_ENV=development
PORT=3000
